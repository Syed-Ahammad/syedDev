# Copy to .env.local and fill in. See docs/deployment-guide.md §3 for the full list.

# MongoDB Atlas connection string (database name: portfolio)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.xxxx.mongodb.net/portfolio

# NextAuth — generate with `npx auth secret` (also accepted as AUTH_SECRET)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
